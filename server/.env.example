# Copie para .env e preencha. O .env NUNCA é commitado (.gitignore).

# Connection string do seu PostgreSQL — única configuração obrigatória
DATABASE_URL=postgresql://usuario:senha@host:5432/banco?sslmode=no-verify

# OPCIONAL: login com GitHub (além do e-mail+senha, que sempre funciona).
# Crie um OAuth App em GitHub → Settings → Developer settings → OAuth Apps
# com callback: https://SEU-DOMINIO/api/auth/github/callback
# Sem estas duas variáveis, o botão GitHub simplesmente não aparece.
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

PORT=3000
NODE_ENV=development
