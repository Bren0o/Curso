# Copie para .env e preencha. O .env NUNCA é commitado (.gitignore).

# Connection string do seu PostgreSQL
DATABASE_URL=postgresql://usuario:senha@host:5432/banco?sslmode=no-verify

# OAuth App do GitHub (Settings → Developer settings → OAuth Apps).
# Identifica o APP, não o usuário — configura uma vez e vale para
# qualquer pessoa que logar. Callback URL do app:
#   https://SEU-DOMINIO/api/auth/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

PORT=3000
NODE_ENV=development
